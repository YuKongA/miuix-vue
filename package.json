{
  "name": "miuix-vue",
  "version": "0.0.0",
  "private": true,
  "description": "Vue 3 port of miuix's visual + animation design language",
  "keywords": [
    "vue",
    "vue3",
    "ui",
    "components",
    "miuix"
  ],
  "license": "Apache-2.0",
  "author": "YuKongA <dev@yukonga.top>",
  "type": "module",
  "main": "./dist/miuix-vue.cjs",
  "module": "./dist/miuix-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/miuix-vue.js",
      "require": "./dist/miuix-vue.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/ playground/"
  },
  "peerDependencies": {
    "motion-v": "^2.0.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.7.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.64.0",
    "eslint-plugin-vue": "~10.9.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "motion-v": "^2.2.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.64.0",
    "prettier": "3.8.3",
    "sass": "^1.99.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.8"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "bun@1.3.2"
}